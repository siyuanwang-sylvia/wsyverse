# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# ∼∼∼ 大文件策略 (SYLVIA PERSONAL UNIVERSE) ∼∼∼
# Git LFS 管理中等大文件（< 2GB）
# LFS 免费额度：1GB 存储 / 1GB 带宽/月
# 超出额度的文件请存入外部图床/云盘，在网站里用链接引用

# LFS 追踪规则（已由 git lfs track 写入 .gitattributes）
# *.pdf, *.mp4, *.mov, *.zip, *.rar, *.psd, *.ai

# 超大文件直接忽略（Git LFS 也传不上去的）
*.iso
*.dmg
*.bin
*.exe
*.msi
*.img
*.gho
*.vmdk
*.vhd
*.vhdx

# 临时文件
*.tmp
*.temp
~$*
Thumbs.db
Desktop.ini

# 系统文件
$RECYCLE.BIN/
System Volume Information/
